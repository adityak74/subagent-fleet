# Generated by subagent-fleet.
# Source: {{ source }}

model_list:
{% for model_name, model in models.items() %}
  - model_name: {{ model.litellm_alias }}
    litellm_params:
      model: ollama_chat/{{ model.ollama_model }}
      api_base: {{ nodes[model.node].endpoint_str }}
      api_key: ollama
      timeout: {{ model.timeout }}
    model_info:
      max_input_tokens: {{ model.context }}
{% endfor %}

litellm_settings:
  drop_params: true
  master_key: os.environ/{{ project.gateway.master_key_env }}

router_settings:
  routing_strategy: simple-shuffle
  num_retries: 1
  timeout: 600

# Generated by subagent-fleet.
# Source: {{ source }}

model_list:
{% for model_name, model in models.items() %}
  - model_name: {{ model.litellm_alias }}
    litellm_params:
      {%- if nodes[model.node].provider == 'ollama' %}
      model: ollama_chat/{{ model.ollama_model }}
{%- else %}
      model: openai/{{ model.ollama_model }}
{%- endif %}
      api_base: {{ nodes[model.node].endpoint_str }}
      api_key: ollama
      timeout: {{ model.timeout }}
{%- if model.fallback and model.fallback in models %}
      fallbacks:
        - {{ models[model.fallback].litellm_alias }}
{%- endif %}
{%- if model.fallback and model.fallback in models %}
      fallbacks:
        - {{ models[model.fallback].litellm_alias }}
{%- endif %}
{%- if model.fallback and model.fallback in models %}
      fallbacks:
        - {{ models[model.fallback].litellm_alias }}
{%- endif %}
    model_info:
      max_input_tokens: {{ model.context }}
{% endfor %}

litellm_settings:
  drop_params: true
  master_key: os.environ/{{ project.gateway.master_key_env }}
{% set callbacks = [] %}
{% if project.observability.langfuse %}{% set _ = callbacks.append('langfuse') %}{% endif %}
{% if project.observability.langsmith %}{% set _ = callbacks.append('langsmith') %}{% endif %}
{% if project.observability.opentelemetry %}{% set _ = callbacks.append('otel') %}{% endif %}
{% if callbacks %}
  success_callbacks:
{% for cb in callbacks %}
    - {{ cb }}
{% endfor %}
  failure_callbacks:
{% for cb in callbacks %}
    - {{ cb }}
{% endfor %}
{% endif %}

router_settings:
  routing_strategy: simple-shuffle
  num_retries: 1
  timeout: 600

# Generated by subagent-fleet.
# Source: {{ source }}

export {{ project.gateway.master_key_env }}="${{ '{' }}{{ project.gateway.master_key_env }}:-sk-local-dev}"

export ANTHROPIC_BASE_URL="http://localhost:{{ project.gateway.port }}"
export ANTHROPIC_AUTH_TOKEN="${{ project.gateway.master_key_env }}"

{% if default_sonnet_model %}
export ANTHROPIC_DEFAULT_SONNET_MODEL="{{ default_sonnet_model }}"
{% endif %}
{% if default_haiku_model %}
export ANTHROPIC_DEFAULT_HAIKU_MODEL="{{ default_haiku_model }}"
{% endif %}

{% if project.observability.langfuse %}
# Langfuse Observability
export LANGFUSE_PUBLIC_KEY="your_public_key"
export LANGFUSE_SECRET_KEY="your_secret_key"
export LANGFUSE_HOST="https://cloud.langfuse.com"
{% endif %}

{% if project.observability.langsmith %}
# LangSmith Observability
export LANGCHAIN_API_KEY="your_api_key"
export LANGCHAIN_PROJECT="{{ project.name }}"
{% endif %}

{% if project.observability.opentelemetry %}
# OpenTelemetry Observability
export OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
{% endif %}
